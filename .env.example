# Leave these blank to run the app in LOCAL mode (data stored in your browser,
# no account or server needed — perfect for a quick demo on GitHub Pages).
#
# To share data between everyone (real accounts + one shared leaderboard),
# create a free project at https://supabase.com, run supabase/schema.sql in the
# SQL editor, then copy the values below from Project Settings > API.
#
# Rename this file to ".env" and fill them in:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
